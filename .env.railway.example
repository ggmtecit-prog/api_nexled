# Railway sample env for NexLed API.
# Copy to Railway variables or to a local private env file.
#
# Important:
# - Cloudinary values below must point to the DAM asset cloud.
# - Current DAM asset cloud used by this repo is `dofqiejpw`.
# - Using another cloud name will make deterministic DAM asset URLs 404.

DB_HOST=tecit.pt
DB_USER_REF=<set-me>
DB_PASS_REF=<set-me>
DB_USER_LAMP=<set-me>
DB_PASS_LAMP=<set-me>
DB_USER_INF=<set-me>
DB_PASS_INF=<set-me>

CLOUDINARY_CLOUD_NAME=dofqiejpw
CLOUDINARY_URL=cloudinary://<api-key>:<api-secret>@dofqiejpw
DAM_CLOUDINARY_URL=cloudinary://<admin-key>:<admin-secret>@dofqiejpw
CLOUDINARY_ADMIN_URL=cloudinary://<admin-key>:<admin-secret>@dofqiejpw
DAM_CLOUDINARY_ADMIN_URL=cloudinary://<admin-key>:<admin-secret>@dofqiejpw

CLOUDINARY_API_KEY=<set-me>
CLOUDINARY_API_SECRET=<set-me>
CLOUDINARY_ADMIN_API_KEY=<set-me>
CLOUDINARY_ADMIN_API_SECRET=<set-me>

API_KEYS=<set-me>
